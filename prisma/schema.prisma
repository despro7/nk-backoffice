generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                    Int             @id @default(autoincrement())
  email                 String          @unique
  name                  String?
  role                  String
  roleName              String?
  password              String
  refreshToken          String?
  refreshTokenExpiresAt DateTime?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  isActive              Boolean         @default(true)
  lastActivityAt        DateTime?
  lastLoginAt           DateTime?
  dilovodUserId         String?         // ID користувача в Діловоді (для відправки документів від його імені)
  OrdersHistory         OrdersHistory[]

  @@map("users")
}

model Order {
  id              Int             @id
  externalId      String          @unique
  orderDate       DateTime?
  quantity        Int
  status          String
  statusText      String
  items           String          @db.LongText
  createdAt       DateTime        @default(now())
  updatedAt       DateTime?
  readyToShipAt   DateTime?       // Дата набуття статусу 3 (Готове до відправки)
  cityName        String?
  customerName    String?
  customerPhone   String?
  provider        String?
  ttn             String
  sajt            String?
  pricinaZnizki   String?
  rawData         String          @db.LongText
  deliveryAddress String?
  lastSynced      DateTime        @default(now())
  orderNumber     String
  paymentMethod   String?
  shippingMethod  String?
  totalPrice      Float?
  syncError       String?
  syncStatus      String          @default("pending")
  dilovodDocId       String?
  dilovodSaleExportDate  DateTime?       // Дата відвантаження в Діловод (documents.sale)
  dilovodSaleDocsCount   Int?            // Кількість документів відвантаження в Діловоді (> 1 = помилка дублікату)
  dilovodExportDate      DateTime?       // Дата вивантаження в Dilovod
  dilovodCashInDate      DateTime?       // Дата додавання документу (documents.cashIn)
  dilovodCashInLastChecked DateTime?     // Дата останньої перевірки cashIn (для уникнення частих запитів)
  dilovodReturnDate      DateTime?       // Дата документа повернення (documents.saleReturn), тільки для статусів 6/7
  dilovodReturnDocsCount Int?            // Кількість документів повернення (> 1 = помилка дублікату)
  OrdersHistory        OrdersHistory[]

  @@index([status])
  @@index([externalId])
  @@index([lastSynced])
  @@index([syncStatus])
  @@index([createdAt])
  @@index([orderDate])
  @@index([orderNumber])
  @@index([status, createdAt])
  @@map("orders")
}

model OrdersHistory {
  id         Int      @id @default(autoincrement())
  orderId    Int
  status     String
  statusText String
  changedAt  DateTime @default(now())
  source     String
  userId     Int?
  notes      String?
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user       User?    @relation(fields: [userId], references: [id])

  @@index([orderId])
  @@index([changedAt])
  @@index([source])
  @@index([userId])
  @@map("orders_history")
}

model Product {
  id                  Int      @id @default(autoincrement())
  sku                 String   @unique
  name                String
  costPerItem         Float?
  currency            String   @default("UAH")
  categoryId          Int?
  categoryName        String?
  set                 String?  @db.LongText
  additionalPrices    String?  @db.LongText
  stockBalanceByStock String?  @db.LongText
  dilovodId           String?
  parent              String?
  lastSyncAt          DateTime @default(now())
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  weight              Int?
  manualOrder         Int?     @default(0)
  barcode             String?
  dilovodDataHash     String?  @db.VarChar(64)
  isOutdated          Boolean  @default(false)
  portionsPerBox      Int      @default(24)

  @@index([sku])
  @@index([categoryId])
  @@index([lastSyncAt])
  @@index([manualOrder])
  @@index([isOutdated])
  @@map("products")
}

model SettingsBoxes {
  id          Int      @id @default(autoincrement())
  name        String
  marking     String
  qntFrom     Int
  qntTo       Int
  width       Int
  height      Int
  length      Int
  overflow    Int      @default(1)
  weight      Decimal  @db.Decimal(10, 2)
  self_weight Decimal  @db.Decimal(10, 3)
  barcode     String?  @db.VarChar(255)
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive])
  @@index([marking])
  @@index([qntFrom])
  @@index([qntTo])
  @@index([barcode])
  @@map("settings_boxes")
}

model SettingsBase {
  id          Int      @id @default(autoincrement())
  key         String   @unique @db.VarChar(255)
  value       String   @db.Text
  description String?  @db.Text
  createdAt   DateTime @default(now()) @db.Timestamp(3)
  updatedAt   DateTime @updatedAt @db.Timestamp(3)
  category    String?  @db.VarChar(100)
  isActive    Boolean  @default(true)

  @@index([category])
  @@index([isActive])
  @@map("settings_base")
}

model SettingsWpSku {
  id          Int      @id @default(autoincrement())
  skus        String   @db.LongText
  lastUpdated DateTime @default(now())
  totalCount  Int      @default(0)

  @@map("settings_wp_sku")
}

model WarehouseMovement {
  id                   Int       @id @default(autoincrement())
  draftCreatedAt       DateTime  @default(now())
  draftLastEditedAt    DateTime  @updatedAt
  movementDate         DateTime? // Дата/час переміщення (використовується для запиту партій та формування payload для Діловода)
  sentToDilovodAt      DateTime? // Дата першої відправки до Діловода
  lastSentToDilovodAt  DateTime? // Дата останньої (проміжної або фінальної) відправки до Діловода
  internalDocNumber    String    @unique @default("00001")
  docNumber            String?   // Номер документа від Діловода (після відправки)
  dilovodDocId         String?   @unique // ID документа в Діловоді (унікальний — для upsert при імпорті з history)
  items                String    @db.LongText
  deviations           String?   @db.LongText
  status               String    @default("draft") // 'draft' | 'active' | 'finalized'
  sourceWarehouse      String
  destinationWarehouse String
  notes                String?
  createdBy            Int

  @@index([status])
  @@index([draftCreatedAt])
  @@index([movementDate])
  @@index([sentToDilovodAt])
  @@index([sourceWarehouse])
  @@index([destinationWarehouse])
  @@index([createdBy])
  @@map("warehouse_movement")
}

model StockMovementHistory {
  id              Int      @id @default(autoincrement())
  productSku      String
  warehouse       String
  movementType    String
  quantity        Float
  quantityType    String
  batchNumber     String?
  referenceId     String?
  referenceType   String?
  previousBalance Float
  newBalance      Float
  movementDate    DateTime @default(now())
  notes           String?
  createdBy       Int?

  @@index([productSku])
  @@index([warehouse])
  @@index([movementType])
  @@index([movementDate])
  @@index([referenceId])
  @@index([referenceType])
  @@map("stock_movement_history")
}

model WarehouseInventory {
  id          Int       @id @default(autoincrement())
  warehouse   String    @default("small")   // Склад: "small" = Малий склад
  status      String    @default("draft")   // draft | in_progress | completed
  comment     String?   @db.Text
  items       String    @db.LongText        // JSON: InventoryProduct[]
  createdBy   Int
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?

  @@index([status])
  @@index([createdBy])
  @@index([createdAt])
  @@index([warehouse])
  @@map("warehouse_inventory")
}

model SyncLogs {
  id               Int       @id @default(autoincrement())
  type             String
  status           String
  message          String    @db.Text
  details          String?   @db.LongText
  startedAt        DateTime  @default(now())
  finishedAt       DateTime?
  duration         BigInt?
  recordsProcessed Int?
  errors           String?   @db.LongText
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([type])
  @@index([status])
  @@index([startedAt])
  @@index([finishedAt])
  @@map("sync_logs")
}

model SyncHistory {
  id            Int      @id @default(autoincrement())
  syncType      String
  startDate     String?
  endDate       String?
  totalOrders   Int
  newOrders     Int
  updatedOrders Int
  skippedOrders Int
  errors        Int
  duration      Float
  details       String   @db.LongText
  status        String
  errorMessage  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  category      String?

  @@map("sync_history")
}

model OrdersCache {
  id             Int      @id @default(autoincrement())
  externalId     String   @unique
  processedItems String?  @db.LongText
  totalQuantity  Int
  totalWeight    Decimal? @db.Decimal(10,2) // Додаємо вагу у кг
  cacheUpdatedAt DateTime @default(now())
  cacheVersion   Int      @default(1)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([externalId])
  @@index([cacheUpdatedAt])
  @@map("orders_cache")
}

model AuthSettings {
  id          Int      @id @default(autoincrement())
  key         String   @unique @db.VarChar(100)
  value       String   @db.VarChar(255)
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamp(3)

  @@map("auth_settings")
}

model ShippingProvider {
  id                Int      @id @default(autoincrement())
  name              String   @db.VarChar(100)  // "Нова Пошта", "Укрпошта"
  providerType      String   @db.VarChar(20)   // "novaposhta", "ukrposhta"
  senderName        String   @db.VarChar(200)  // "ФОП Бубнов С.В.", "ФОП Бубнова М.В."
  senderId          Int?                       // Ідентифікатор відправника в SalesDrive
  isActive          Boolean  @default(false)   // Активний провайдер
  order             Int      @default(0)       // Порядок сортування
  
  // API ключі для Нової Пошти
  apiKey            String?  @db.VarChar(500)  // API ключ НП
  
  // API ключі для Укрпошти
  bearerEcom        String?  @db.VarChar(500)  // Bearer токен для ecom
  counterpartyToken String?  @db.VarChar(500)  // Counterparty токен
  bearerStatus      String?  @db.VarChar(500)  // Bearer токен для статусів
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([providerType])
  @@index([isActive])
  @@index([order])
  @@map("shipping_providers")
}
model Material {
  id                   Int      @id @default(autoincrement())
  dilovodId            String   @unique          // ID товару в Діловоді
  sku                  String?  @unique          // productNum (артикул)
  name                 String                    // Назва матеріалу
  parentId             String                    // ID батьківської папки в Діловоді
  categoryId           Int?                      // ID категорії (з назви папки, якщо є)
  categoryName         String?                   // Назва категорії / папки
  barcode              String?                   // Штрих-код (заповнюється вручну)
  stockBalanceByStock  String?  @db.LongText     // JSON: залишки по складам (e.g., {"1": 100, "2": 50})
  manualOrder          Int      @default(0)      // Ручне сортування
  isActive             Boolean  @default(true)   // false = більше немає в Діловоді
  lastSyncAt           DateTime @default(now())
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([sku])
  @@index([parentId])
  @@index([isActive])
  @@index([manualOrder])
  @@map("materials")
}

model meta_logs {
  id          Int      @id @default(autoincrement())
  datetime    DateTime @default(now())
  category    String   @db.VarChar(32)
  title       String?  @db.VarChar(255)
  status      String   @db.VarChar(16)
  message     String?
  data        Json?
  readBy      Json?    // { [userId]: "ISO", "_all": "ISO" } — хто і коли прочитав
  hiddenBy    Json?    // { [userId]: "ISO", "_all": "ISO" } — хто і коли приховав
  orderNumber String?  @db.VarChar(128)
  initiatedBy String?  @db.VarChar(128) // Ініціатор дії: userId (число) або "cron:назва", "webhook:назва", "system:назва"

  @@index([orderNumber])
  @@index([initiatedBy])
}

